# Environment variables (set these in Railway → Variables). All optional — there are defaults.
# Setting them in production keeps the password OUT of the code and lets you change it without a deploy.

# Login credentials
ADMIN_USER=מאמוש
ADMIN_PASS=מאמוש2013

# Shared bearer token issued on login (change to any random string in production)
AUTH_TOKEN=change-me-to-a-random-string

# Railway sets PORT automatically — do NOT set it manually there.
# DATA_DIR defaults to /app/data (the persistent volume mount point).
